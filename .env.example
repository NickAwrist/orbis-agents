# Optional local overrides.
# Leave values unset to keep the current defaults.

# Backend API port. Defaults to 3000. In Docker, this is the container port.
AGENTS_BACKEND_PORT=3000

# Backend bind host. Defaults to 127.0.0.1 for local runs.
AGENTS_BACKEND_HOST=127.0.0.1

# Vite frontend port for dev. In Docker, this is the host-facing UI port.
# Docker Compose defaults this host-facing port to 3000 when unset.
AGENTS_FRONTEND_PORT=5174

# Ollama endpoint. Defaults to ollama-js local behavior.
AGENTS_OLLAMA_HOST=http://127.0.0.1:11434

# ComfyUI endpoint. Defaults to http://127.0.0.1:8188.
AGENTS_COMFYUI_HOST=http://127.0.0.1:8188
